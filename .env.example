# ─── AI Provider Configuration ───
# 
# Options: ollama (default), openrouter, builtin
AI_PROVIDER=ollama

# Ollama settings (used when AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:latest

# OpenRouter settings (used when AI_PROVIDER=openrouter)
# Get your API key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=your_openrouter_key_here
# OPENROUTER_MODEL=openai/gpt-4o-mini

# ─── Obsidian Vault Memory ───
# Path to Obsidian vault directory for persistent AI memory
# Defaults to ./OpenFriday (relative to project root)
# OBSIDIAN_VAULT_PATH=
